rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function currentMember() {
      return firestore.get(/databases/(default)/documents/members/$(request.auth.uid));
    }

    function managementRole(memberData) {
      return memberData.leadershipRole == 'Desenvolvedor'
        ? 'developer'
        : memberData.accountLevel == 'administration'
          ? 'admin'
          : memberData.leadershipRole == 'Maestro'
            ? 'maestro'
            : memberData.leadershipRole == 'Secretário'
              ? 'secretary'
              : memberData.leadershipRole == 'Vice-Secretário'
                ? 'vice-secretary'
                : 'member';
    }

    function targetMember(userId) {
      return firestore.get(/databases/(default)/documents/members/$(userId));
    }

    function songLibraryItem(songId) {
      return firestore.get(/databases/(default)/documents/songLibrary/$(songId));
    }

    function isSongOwner(songId) {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/songLibrary/$(songId)) &&
        songLibraryItem(songId).data.createdByUid == request.auth.uid;
    }

    function canManageRole(actorRole, targetRole, actorUid, targetUid) {
      return actorUid != targetUid && (
        actorRole == 'admin' ||
        (actorRole == 'developer' && targetRole != 'admin') ||
        (actorRole == 'maestro' && targetRole != 'admin' && targetRole != 'developer') ||
        ((actorRole == 'secretary' || actorRole == 'vice-secretary') &&
          (targetRole == 'member' || targetRole == 'secretary' || targetRole == 'vice-secretary'))
      );
    }

    function canManageMemberAvatar(userId) {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/members/$(userId)) &&
        canManageRole(
          managementRole(currentMember().data),
          managementRole(targetMember(userId).data),
          request.auth.uid,
          userId
        );
    }

    function isAdmin() {
      return signedIn() && currentMember().data.accountLevel == 'administration';
    }

    function isDeveloper() {
      return signedIn() && currentMember().data.leadershipRole == 'Desenvolvedor';
    }

    function isDirectionLeader() {
      return signedIn() && (
        currentMember().data.leadershipRole == 'Maestro' ||
        currentMember().data.leadershipRole == 'Secretário' ||
        currentMember().data.leadershipRole == 'Vice-Secretário'
      );
    }

    function canDeleteManagedMedia() {
      return isAdmin() || (
        signedIn() && (
          currentMember().data.leadershipRole == 'Maestro' ||
          currentMember().data.leadershipRole == 'Secretário'
        )
      );
    }

    function hasPermission(permission) {
      return signedIn() &&
        currentMember().data.permissions is list &&
        currentMember().data.permissions.hasAny([permission]);
    }

    function canManagePostMedia() {
      return isAdmin() ||
        isDirectionLeader() ||
        hasPermission('Postar avisos') ||
        hasPermission('Mexer na agenda');
    }

    function canManageSongMedia() {
      return isAdmin() ||
        isDeveloper() ||
        isDirectionLeader() ||
        hasPermission('Adicionar músicas');
    }

    function canViewAllSongMedia() {
      return isAdmin() ||
        isDeveloper() ||
        (
          signedIn() && (
            currentMember().data.leadershipRole == 'Maestro' ||
            currentMember().data.leadershipRole == 'Secretário'
          )
        );
    }

    function isImageUpload() {
      return request.resource != null &&
        request.resource.contentType.matches('image/.*');
    }

    function isVideoUpload() {
      return request.resource != null &&
        request.resource.contentType.matches('video/.*');
    }

    function isAudioUpload() {
      return request.resource != null &&
        request.resource.contentType.matches('audio/.*');
    }

    function isPdfOrImageUpload() {
      return request.resource != null && (
        request.resource.contentType == 'application/pdf' ||
        request.resource.contentType.matches('image/.*')
      );
    }

    function memberMatchesVocalRange(acceptedRanges) {
      return signedIn() &&
        currentMember().data.vocalRange is string &&
        acceptedRanges.hasAny([currentMember().data.vocalRange]);
    }

    function voiceFolderMatchesMember(voiceType) {
      return voiceType == 'geral' || (
        voiceType == 'soprano' &&
        memberMatchesVocalRange(['Soprano', 'soprano'])
      ) || (
        voiceType == 'mezzo-soprano' && (
          memberMatchesVocalRange([
            'Mezzo-soprano',
            'Mezzo Soprano',
            'Mezzo soprano',
            'mezzo-soprano',
            'mezzo soprano'
          ])
        )
      ) || (
        voiceType == 'contralto' &&
        memberMatchesVocalRange(['Contralto', 'contralto'])
      ) || (
        voiceType == 'tenor' &&
        memberMatchesVocalRange(['Tenor', 'tenor'])
      ) || (
        voiceType == 'baritono' && (
          memberMatchesVocalRange([
            'Barítono',
            'Baritono',
            'barítono',
            'baritono'
          ])
        )
      ) || (
        voiceType == 'baixo' &&
        memberMatchesVocalRange(['Baixo', 'baixo'])
      );
    }

    match /avatars/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if signedIn() &&
        (request.auth.uid == userId || canManageMemberAvatar(userId)) &&
        isImageUpload() &&
        request.resource.size <= 5 * 1024 * 1024;
      allow delete: if signedIn() && (request.auth.uid == userId || canManageMemberAvatar(userId));
    }

    match /posts/{postId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if canManagePostMedia() && (
        (isImageUpload() && request.resource.size <= 15 * 1024 * 1024) ||
        (isVideoUpload() && request.resource.size <= 150 * 1024 * 1024)
      );
      allow delete: if canDeleteManagedMedia();
    }

    match /songs/{songId}/voices/{voiceType}/{fileName} {
      allow read: if canViewAllSongMedia() || isSongOwner(songId) || (signedIn() && voiceFolderMatchesMember(voiceType));
      allow create, update: if (canManageSongMedia() || isSongOwner(songId)) &&
        isAudioUpload() &&
        request.resource.size <= 80 * 1024 * 1024;
      allow delete: if canDeleteManagedMedia() || isSongOwner(songId);
    }

    match /songs/{songId}/{attachmentType}/{fileName} {
      allow read: if (signedIn() && attachmentType in ['lyrics', 'score']) || canViewAllSongMedia() || isSongOwner(songId);
      allow create, update: if (canManageSongMedia() || isSongOwner(songId)) &&
        attachmentType in ['lyrics', 'score'] &&
        isPdfOrImageUpload() &&
        request.resource.size <= 25 * 1024 * 1024;
      allow delete: if canDeleteManagedMedia() || isSongOwner(songId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}