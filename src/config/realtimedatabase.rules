{
	"rules": {
		".read": false,
		".write": false,
		"presence": {
			"$uid": {
				".read": "auth != null && auth.uid === $uid",
				".write": "auth != null && auth.uid === $uid",
				".validate": "newData.hasChildren(['state', 'displayName', 'lastChanged']) && newData.child('state').isString() && (newData.child('state').val() === 'online' || newData.child('state').val() === 'offline') && newData.child('displayName').isString() && newData.child('displayName').val().length <= 80 && newData.child('lastChanged').isNumber()"
			}
		}
	}
}
