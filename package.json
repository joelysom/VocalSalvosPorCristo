{
  "name": "vocal-spc",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "cap:copy": "npm run build && node ./node_modules/@capacitor/cli/bin/capacitor copy",
    "cap:sync": "npm run build && node ./node_modules/@capacitor/cli/bin/capacitor sync",
    "cap:add:android": "node ./node_modules/@capacitor/cli/bin/capacitor add android",
    "cap:open:android": "node ./node_modules/@capacitor/cli/bin/capacitor open android",
    "apk:debug": "cmd.exe /d /c scripts\\build-android-on-d.cmd -Dorg.gradle.jvmargs= assembleDebug --no-daemon --console=plain",
    "apk:release": "cmd.exe /d /c scripts\\build-android-on-d.cmd -Dorg.gradle.jvmargs= assembleRelease --no-daemon --console=plain",
    "aab:release": "cmd.exe /d /c scripts\\build-android-on-d.cmd -Dorg.gradle.jvmargs= bundleRelease --no-daemon --console=plain",
    "vercel:preview": "vercel",
    "deploy:vercel": "vercel --prod"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.1",
    "@capacitor/cli": "^7.6.1",
    "@capacitor/core": "^7.6.1",
    "cep-promise": "^4.4.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "lucide-react": "^1.7.0",
    "nodemailer": "^8.0.5",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-easy-crop": "^5.5.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vercel": "^50.39.0",
    "vite": "^6.4.1"
  }
}
